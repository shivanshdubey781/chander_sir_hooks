[Unit]
Description=Chartlink Webhook to Telegram Bridge
After=network.target

[Service]
User=www-data
WorkingDirectory=/var/www/chartlink-bridge
ExecStart=/var/www/chartlink-bridge/venv/bin/uvicorn main:app --host 0.0.0.0 --port 7012
Restart=always
EnvironmentFile=/var/www/chartlink-bridge/.env

[Install]
WantedBy=multi-user.target
